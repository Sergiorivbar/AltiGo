# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgres://altigo:altigo@localhost:5432/altigo_db

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Stripe (TEST mode keys only — never use live keys here)
# Get these from your Stripe dashboard in test mode: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=replace-with-your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-test-webhook-secret
PREMIUM_PRICE_ID=replace-with-your-stripe-test-price-id

# Mapbox (used server-side for static map previews / geocoding, optional)
MAPBOX_ACCESS_TOKEN=replace-with-your-mapbox-access-token
